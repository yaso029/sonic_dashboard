# Sonic / Accounting CRM — environment template.
# Copy to `.env` for local dev. Everything below has safe local defaults; the app
# runs fully offline with no external services when left unset.

# ─── Core ──────────────────────────────────────────────────────────────────────
# Local SQLite by default. Do NOT point this at the production Postgres URL.
DATABASE_URL=sqlite:///./crm_local.db
# Override in any real deployment — also signs document download tokens (Phase 4).
SECRET_KEY=change-me-in-production

# ─── Phase 4: document storage ──────────────────────────────────────────────────
# Backend selector: "local" (default) writes files to STORAGE_DIR on disk.
# "s3" / "supabase" are reserved — implement a Storage subclass in
# backend/services/storage_service.py and return it from get_storage().
STORAGE_BACKEND=local
# Where local files live (default: <cwd>/storage/documents). This dir is gitignored.
STORAGE_DIR=./storage/documents
# Max single-upload size in bytes (default 25 MB).
MAX_UPLOAD_BYTES=26214400

# When STORAGE_BACKEND=s3 (future), the adapter would read these:
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# When STORAGE_BACKEND=supabase (future):
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_BUCKET=

# ─── Phase 5: billing / Stripe (TEST MODE ONLY, optional) ────────────────────────
# Leave blank to run billing in fully-local manual mode (invoices + manual payment
# recording, no network). To enable card payments, set a Stripe TEST key (sk_test_…).
# A live key (sk_live_…) is REFUSED on purpose so this can never move real money.
STRIPE_SECRET_KEY=
# Publishable key (pk_test_…) — safe to expose to the browser; used by the frontend.
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…) — only needed if you run `stripe listen` / a
# tunnel. The /api/invoices/{id}/sync-stripe endpoint reconciles without webhooks.
STRIPE_WEBHOOK_SECRET=

# ─── Phase 9: login rate limiting / lockout (lenient defaults) ───────────────────
# In-memory limiter (a backend restart clears all lockouts, so it can never
# permanently lock you out). Applies to staff + portal login endpoints.
LOGIN_MAX_ATTEMPTS=5      # failures within the window before a temporary lock
LOCKOUT_MINUTES=5         # how long an account stays locked (auto-expires)
LOGIN_WINDOW_MINUTES=5    # rolling window over which failures are counted

# ─── Phase 7: AI document analysis (Anthropic Claude, optional) ──────────────────
# Leave blank to run fully offline — the UAE tax compliance checklist is
# deterministic and always works. Set a key to enable AI document analysis
# (vision extraction + summarise/classify). Endpoints return 503 without a key.
ANTHROPIC_API_KEY=
# Model used for analysis (default claude-sonnet-4-6). Opus/Haiku also valid.
AI_MODEL=claude-sonnet-4-6

# ─── Video Studio: Kling AI video generation (optional) ──────────────────────────
# Leave blank to disable the Video Studio module (endpoints return 503). Get keys
# from the Kling developer console and TOP UP a Resource Package, else the API
# returns "429 Account balance not enough". Keep these SECRET (never commit them).
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# International (Singapore) endpoint by default; for China mainland use
# https://api.klingai.com
KLING_BASE_URL=https://api-singapore.klingai.com

# ─── Legacy / optional integrations (image uploads for HR + e-cards) ─────────────
# Cloudinary is used only by the HR photo / e-card image features; leave blank to
# disable those uploads. Client documents (Phase 4) do NOT use Cloudinary.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
